# Copy this file to .env and fill in your API keys.
# Get Gemini API keys from: https://aistudio.google.com/app/apikey

# You can use separate keys for each feature, or reuse the same key if your quota allows it.


# Main Gemini key (skills extraction + study plan generation)
GEMINI_API_KEY=

# Gemini key for Module 3 assessment question generation
QUESTION_GEMINI_API_KEY=

# Gemini key for Module 5 final practice test generation
PRACTICE_TEST_GEMINI_API_KEY=

# Comma-separated frontend URLs allowed by CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
